<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<!--
		  IntegraDb: template da connection string para o PostgreSQL do Integra ERP.
		  Host= é injetado em runtime a partir de db_config.txt (editavel pela engrenagem).
		  Password= é deliberadamente vazia: deve ser preenchida apos a instalacao
		  (manualmente neste arquivo ou via tela de configuracao).
		  SSL Mode=Prefer (obrigatorio - tenta SSL, cai para sem-SSL se servidor nao suportar).
		-->
		<add name="IntegraDb"
		     connectionString="Username=postgres;Password=;Database=integrapgsql;Port=5432;Timeout=5;Command Timeout=5;Keepalive=10;TCP Keepalive=true;SSL Mode=Prefer;Trust Server Certificate=true;"
		     providerName="Npgsql" />
	</connectionStrings>
</configuration>
